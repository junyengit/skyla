{
  "name": "skyla",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.4.0-canary.1",
  "engines": {
    "bun": ">=1.4.0-canary.1",
    "node": "24.x"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ],
  "overrides": {
    "postcss": "8.5.16"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "bun run test:unit",
    "test:unit": "turbo test:unit && bun run convex:test:unit",
    "test:smoke": "node scripts/smoke/route-smoke.mjs",
    "test:payments": "node scripts/smoke/payment-api-smoke.mjs",
    "test:production-readiness": "node scripts/smoke/production-readiness-smoke.mjs",
    "convex:test:unit": "vitest run convex",
    "convex:env:check": "node scripts/setup/check-convex-env.mjs",
    "convex:schema:typecheck": "tsc --noEmit --target ES2022 --module ESNext --moduleResolution Bundler --strict --skipLibCheck convex/schema.ts",
    "convex:functions:typecheck": "tsc -p convex/tsconfig.json --noEmit",
    "convex:codegen": "convex codegen --typecheck enable",
    "security": "bun run security:artifacts && bun run security:audit",
    "security:artifacts": "node scripts/security/check-tracked-artifacts.mjs",
    "security:audit": "bun audit --audit-level=high",
    "check": "turbo lint typecheck test:unit build && bun run convex:test:unit && bun run convex:schema:typecheck && bun run convex:functions:typecheck && bun run security:artifacts",
    "web:dev": "bun run --cwd apps/web dev",
    "web:build": "bun run --cwd apps/web build",
    "web:start": "bun run --cwd apps/web start"
  },
  "devDependencies": {
    "typescript": "6.0.3",
    "turbo": "2.10.2",
    "vitest": "4.1.9"
  },
  "dependencies": {
    "@skyla/payments": "workspace:*",
    "convex": "^1.42.1"
  }
}
