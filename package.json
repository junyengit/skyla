{
  "name": "skyla",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "pnpm test:unit",
    "test:unit": "turbo test:unit",
    "test:smoke": "node scripts/smoke/route-smoke.mjs",
    "security": "pnpm security:artifacts && pnpm security:audit",
    "security:artifacts": "node scripts/security/check-tracked-artifacts.mjs",
    "security:audit": "pnpm audit --audit-level=high",
    "check": "turbo lint typecheck test:unit build && pnpm security:artifacts",
    "web:dev": "pnpm --filter @skyla/web dev",
    "web:build": "pnpm --filter @skyla/web build",
    "web:start": "pnpm --filter @skyla/web start"
  },
  "devDependencies": {
    "turbo": "2.10.1",
    "vitest": "4.1.9"
  }
}
